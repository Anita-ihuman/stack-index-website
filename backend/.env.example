# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:8080

# API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
GITHUB_TOKEN=ghp_your-github-token-here

# Contact form email (Gmail SMTP)
CONTACT_RECIPIENT=thestackindex@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=thestackindex@gmail.com
SMTP_PASS=your-gmail-app-password-here

# Brevo (newsletter)
BREVO_API_KEY=your-brevo-api-key-here
BREVO_LIST_ID=                         # optional — numeric ID of your Brevo list

# Optional API Keys
STACKOVERFLOW_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Cache Configuration (Redis is optional — leave REDIS_URL blank to use in-memory cache)
REDIS_URL=
REDIS_PASSWORD=
CACHE_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# Logging
LOG_LEVEL=info
ENABLE_METRICS=true
